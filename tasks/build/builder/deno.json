{
  "name": "@design-system/builder",
  "version": "0.1.0",
  "exports": "./mod.ts",
  "exclude": ["modules/", "react-component/"],
  "nodeModulesDir": "auto",
  "imports": {
    "./": "./",
    "/": "./",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@std/cli": "jsr:@std/cli@^1.0.23",
    "lightningcss": "npm:lightningcss@^1.32.0",
    "rolldown": "npm:rolldown@^1.1.3",
    "rollup-plugin-gzip": "npm:rollup-plugin-gzip@^4.2.0",
    "rollup-plugin-svg": "npm:rollup-plugin-svg@^2.0.0",
    "rollup-plugin-brotli": "npm:rollup-plugin-brotli@^3.1.0",
    "rollup-plugin-sass": "npm:rollup-plugin-sass@^1.16.0-rc.1",
    "rollup-plugin-swc3": "npm:rollup-plugin-swc3@^0.12.1",
    "@swc/core": "npm:@swc/core@^1.15.43",
    "rollup": "npm:rollup@^4.62.2",
    "sass": "npm:sass@^1.101.0",
    "@rollup/plugin-typescript": "npm:@rollup/plugin-typescript@^12.3.0",
    "@rollup/plugin-replace": "npm:@rollup/plugin-replace@^6.0.3",
    "@rollup/plugin-terser": "npm:@rollup/plugin-terser@^1.0.0",
    "unplugin-lightningcss": "npm:unplugin-lightningcss@^0.4.5",
    "chalk": "npm:chalk@^5.6.2"
  },
  
  "tasks": {
    "build": {
      "description": "Run the builder CLI from this package source.",
      "command": "deno run --allow-all ./cli.ts $1"
    }
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "deno.ns"
    ]
  }
}
