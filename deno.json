{
  "name": "@design-system/all",
  "version": "0.0.5",
  "exports": "./mod.ts",
  "tasks": {
    "build": {
      "description": "Build design-system packages using the local builder source.",
      "command": "deno run --allow-run --allow-read --allow-write --allow-net --allow-env --allow-sys --allow-ffi ./tasks/build/build.ts --path=./config/build-config.ts"
    },
    "build-package": {
      "description": "Build design-system packages using the published JSR builder package.",
      "command": "deno run --allow-run --allow-read --allow-write --allow-net --allow-env --allow-sys --allow-ffi jsr:@design-system/builder@0.0.12 build --path=./config/build-config.ts"
    },
    "start": {
      "description": "Start the mock API and Storybook development server.",
      "command": "deno task mock & deno task storybook"
    },
    "storybook": {
      "description": "Start Storybook on port 3100.",
      "command": "storybook dev -p 3100 --config-dir .storybook"
    },
    "build-storybook": {
      "description": "Build the static Storybook site.",
      "command": "storybook build"
    },
    "mock": {
      "description": "Start the mock API service from the mock workspace.",
      "command": "deno task --cwd ./mock start"
    },
    "install-git-hooks": {
      "description": "Install commit-message hooks for the root repo and submodules.",
      "command": "deno run --allow-read --allow-write --allow-run tasks/git-hooks/install-git-hooks.ts"
    }
  },
  "exclude": ["modules/", "react-component/"],
  "imports": {
    "./": "./",
    "/": "./",
    "@std/path": "jsr:@std/path@^1.1.2",
    "@std/cli": "jsr:@std/cli@^1.0.23",
    "rolldown": "npm:rolldown@^1.1.3",
    "rollup-plugin-gzip": "npm:rollup-plugin-gzip@^4.2.0",
    "rollup-plugin-sass": "npm:rollup-plugin-sass@^1.16.0-rc.1",
    "rollup-plugin-swc3": "npm:rollup-plugin-swc3@^0.12.1"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns"
    ]
  }
}
